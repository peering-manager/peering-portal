# Peering Portal configuration.

# Peering Manager URL (no trailing slash)
PM_URL=https://peering.example.com

# Peering Manager API token
PM_TOKEN=your-api-token-here

# Secret used to sign the wizard's session cookie. Set this to a long random
# value in production, e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`.
SECRET_KEY=change-me-in-production

HOST=0.0.0.0
PORT=8080

# Set to 1 to enable uvicorn auto-reload (dev only)
RELOAD=
